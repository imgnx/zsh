boxify() {
    awk '
  BEGIN {
    width = 103
    inner = width - 8
    border = ""
    for (i = 1; i <= width; i++) border = border "#"
    print border | "lolcat"
    close("lolcat")
  }
  {
    line = substr($0, 1, inner)
    printf "###\n%s\n###\n", line
  }
  END {
    print border | "lolcat"
    close("lolcat")
  }' | awk '
    NR % 3 == 1 {
      printf "%s", $0 | "lolcat"
      close("lolcat")
      next
    }
    NR % 3 == 2 {
      printf "\033[97m %-*s \033[0m\n", 95, $0
      next
    }
    NR % 3 == 0 {
      printf "%s\n", $0 | "lolcat"
      close("lolcat")
    }'
}

