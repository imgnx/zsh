#compdef math2img

autoload -U is-at-least

_math2img() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" \
'-o+[Output filename]:OUTPUT:_files' \
'--output=[Output filename]:OUTPUT:_files' \
'--completion=[Generate shell completion]:SHELL:(bash elvish fish powershell zsh)' \
'-w+[Number of horizontal dots in PNG image]:WIDTH: ' \
'--width=[Number of horizontal dots in PNG image]:WIDTH: ' \
'-h+[Number of vertical dots in PNG image]:HEIGHT: ' \
'--height=[Number of vertical dots in PNG image]:HEIGHT: ' \
'--help[Print help]' \
'--png[Output as PNG. If the argument \`output\` has a \`.png\` extension, it will be set automatically]' \
'-V[Print version]' \
'--version[Print version]' \
'::math -- Mathjax expression:' \
&& ret=0
}

(( $+functions[_math2img_commands] )) ||
_math2img_commands() {
    local commands; commands=()
    _describe -t commands 'math2img commands' commands "$@"
}

if [ "$funcstack[1]" = "_math2img" ]; then
    _math2img "$@"
else
    compdef _math2img math2img
fi
